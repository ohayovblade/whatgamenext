# Copy to .env.local and fill in. Never commit .env.local.

# Postgres connection (DBeaver-friendly). Matches the local Docker container:
#   docker run -d --name whatgamenext-pg -e POSTGRES_USER=postgres \
#     -e POSTGRES_PASSWORD=whatgamenext -e POSTGRES_DB=whatgamenext -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:whatgamenext@localhost:5432/whatgamenext

# NextAuth — secret used to sign session JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# RAWG API (game search) — not required for the auth feature, here for completeness.
RAWG_API_KEY=
